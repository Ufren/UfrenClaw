    "glob": "11.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "mlly": "1.7.4",
    "openclaw": "2026.3.13",
    "playwright": "^1.54.2",
    "postcss": "^8.5.1",
    "prettier": "^3.6.2",
    "sass": "^1.77.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "vite": "^7.3.1",
    "zx": "^8.8.5"
  },
  "license": "ISC",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "@parcel/watcher",
      "@scarf/scarf",
      "@swc/core",
      "@whiskeysockets/baileys",
      "core-js",
      "electron",
      "esbuild",
      "koffi",
