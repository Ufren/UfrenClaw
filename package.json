{
  "name": "UfrenClaw",
  "description": "Secure boilerplate for Electron app based on Vite",
  "version": "3.1.5",
  "private": true,
  "type": "module",
  "author": "scx&&cyt",
  "main": "packages/entry-point.mjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "cross-env VITE_RENDERER=react node packages/dev-mode.js",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:go": "cd native/selection-monitor && go build -ldflags=\"-H windowsgui -s -w\" -o selection-monitor.exe main.go",
    "build:main": "cross-env VITE_TARGET=main vite build",
    "build:preload": "cross-env VITE_TARGET=preload vite build",
    "build:renderer": "tsc -p packages/renderer-react/tsconfig.app.json --noEmit && cross-env VITE_TARGET=renderer VITE_RENDERER=react vite build --base ./",
    "compile": "node packages/dev-compile.mjs",
    "compile:base": "npm run build && zx scripts/bundle-openclaw.mjs && zx scripts/bundle-openclaw-plugins.mjs && zx scripts/bundle-preinstalled-skills.mjs && electron-builder build --config electron-builder.yml",
    "test": "node ./node_modules/@playwright/test/cli.js test ./tests/e2e.spec.ts",
    "start": "cross-env VITE_RENDERER=react node packages/dev-mode.js",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w sqlite3",
    "create-renderer": "cd packages && node ./integrate-renderer/create-renderer.js",
    "integrate-renderer": "node packages/integrate-renderer/index.js --no-warnings",
    "init": "npm run create-rend        erer && npm run integrate-renderer && npm install",
    "lint": "eslint packages/main/src packages/preload/src packages/renderer-react/src packages/*.mjs vite.config.ts electron-builder.mjs eslint.config.js .lintstagedrc.js --fix",
    "lint:check": "eslint packages/main/src packages/preload/src packages/renderer-react/src packages/*.mjs vite.config.ts electron-builder.mjs eslint.config.js .lintstagedrc.js",
    "format": "prettier --write packages/main/src packages/preload/src packages/renderer-react/src packages/*.mjs vite.config.ts electron-builder.mjs eslint.config.js .lintstagedrc.js",
    "format:check": "prettier --check packages/main/src packages/preload/src packages/renderer-react/src packages/*.mjs vite.config.ts electron-builder.mjs eslint.config.js .lintstagedrc.js",
    "clean": "rm -rf packages/*/dist packages/*/node_modules || rmdir /s /q packages\\*\\dist packages\\*\\node_modules",
    "rebuild:all": "electron-rebuild",
    "prepare": "husky",
    "install:clean": "rimraf node_modules package-lock.json && npm install",
    "install:pnpm": "rimraf node_modules pnpm-lock.yaml && pnpm install"
  },
  "dependencies": {
    "@copilotkit/a2ui-renderer": "^1.50.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/highlight.js": "^10.1.0",
    "@types/html2canvas": "^0.5.35",
    "@types/markdown-it": "^14.1.2",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "@xterm/addon-fit": "^0.11.0",
    "class-variance-authority": "^0.7.1",
    "clawhub": "^0.5.0",
    "clsx": "^2.1.1",
    "docx": "^9.3.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.35.2",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.14",
    "idb": "^8.0.3",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.473.0",
    "markdown-it": "^14.1.0",
    "marked": "^16.4.0",
    "ms": "^2.1.3",
    "node-fetch": "^3.3.2",
    "node-machine-id": "^1.1.12",
